{
  "note": "OpenClaw Agent Team example config fragment. Adjust fields to your real instance.",
  "models": {
    "providers": {
      "primary": {
        "type": "openai",
        "apiKey": "$LLM_API_KEY"
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "primary/$MODEL_FAST"
      }
    },
    "list": [
      {
        "id": "main",
        "model": {
          "primary": "primary/$MODEL_STRONG"
        },
        "identity": {
          "name": "墨影",
          "theme": "主 Agent / 总控。先判断任务复杂度与风险，简单任务直接执行，复杂任务再拆解、审议与放行。"
        },
        "subagents": {
          "allowAgents": ["chengshu", "tanzhen", "biguan", "guanxiang", "tieshou", "wenxi", "pianchang"]
        }
      },
      {
        "id": "chengshu",
        "identity": {
          "name": "承枢",
          "theme": "编排协调 Agent。负责多步骤任务的状态推进、handoff 回收、阻塞暴露与阶段汇总，不做最终裁决与放行。"
        },
        "subagents": {
          "allowAgents": ["tanzhen", "biguan", "guanxiang", "tieshou", "wenxi", "pianchang"]
        }
      },
      {
        "id": "tanzhen",
        "identity": {
          "name": "探针",
          "theme": "研究情报 Agent。负责资料检索、文档调研、方案对比、竞品研究。"
        }
      },
      {
        "id": "biguan",
        "identity": {
          "name": "笔官",
          "theme": "内容策划写作 Agent。负责成稿、提纲、脚本、改写、润色。"
        }
      },
      {
        "id": "guanxiang",
        "identity": {
          "name": "观象",
          "theme": "日常运营 / 例行执行 / structured ops Agent。负责巡检、cron、定时汇总和稳定结构化任务执行。"
        }
      },
      {
        "id": "tieshou",
        "identity": {
          "name": "铁手",
          "theme": "研发执行 Agent。负责编码、脚本、自动化、小功能实现。"
        }
      },
      {
        "id": "wenxi",
        "identity": {
          "name": "问隙",
          "theme": "测试排障 Agent。负责复现 bug、日志分析、回归建议与放行判断。"
        }
      },
      {
        "id": "pianchang",
        "identity": {
          "name": "片场",
          "theme": "多媒体调度中枢。先判断是生图、视频还是修图，再决定是否下发专项执行单元。"
        }
      }
    ]
  },
  "bindings": [
    { "agentId": "main", "channel": "discord", "accountId": "main-bot" },
    { "agentId": "chengshu", "channel": "discord", "accountId": "chengshu-bot" },
    { "agentId": "tanzhen", "channel": "discord", "accountId": "tanzhen-bot" },
    { "agentId": "biguan", "channel": "discord", "accountId": "biguan-bot" },
    { "agentId": "guanxiang", "channel": "discord", "accountId": "guanxiang-bot" },
    { "agentId": "tieshou", "channel": "discord", "accountId": "tieshou-bot" },
    { "agentId": "wenxi", "channel": "discord", "accountId": "wenxi-bot" },
    { "agentId": "pianchang", "channel": "discord", "accountId": "pianchang-bot" }
  ],
  "channels": {
    "discord": {
      "accounts": {
        "main-bot": {
          "token": "$DISCORD_BOT_TOKEN_MAIN",
          "groupPolicy": "open"
        },
        "chengshu-bot": {
          "token": "$DISCORD_BOT_TOKEN_CHENGSHU",
          "groupPolicy": "open"
        },
        "tanzhen-bot": {
          "token": "$DISCORD_BOT_TOKEN_TANZHEN",
          "groupPolicy": "open"
        },
        "biguan-bot": {
          "token": "$DISCORD_BOT_TOKEN_BIGUAN",
          "groupPolicy": "open"
        },
        "guanxiang-bot": {
          "token": "$DISCORD_BOT_TOKEN_GUANXIANG",
          "groupPolicy": "open"
        },
        "tieshou-bot": {
          "token": "$DISCORD_BOT_TOKEN_TIESHOU",
          "groupPolicy": "open"
        },
        "wenxi-bot": {
          "token": "$DISCORD_BOT_TOKEN_WENXI",
          "groupPolicy": "open"
        },
        "pianchang-bot": {
          "token": "$DISCORD_BOT_TOKEN_PIANCHANG",
          "groupPolicy": "open"
        }
      }
    }
  }
}
